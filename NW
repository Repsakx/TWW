local TrackedTargets = {}

local function ScanEntities()
    local activeKeys = {}

    -- GRACZE (zawsze skanowani, jeśli włączone ESP lub Aimbot)
    if SETTINGS.PlayerESP or SETTINGS.AimbotEnabled then
        local chars = workspace:FindFirstChild("Characters")
        if chars then
            for _, char in pairs(chars:GetChildren()) do
                local hrp = char:FindFirstChild("HumanoidRootPart")
                if hrp then
                    local key = "PLAYER_" .. char.Name
                    activeKeys[key] = true
                    local plr = Players:FindFirstChild(char.Name)
                    local color = GetPlayerColor(plr)
                    TrackedTargets[key] = { Part = hrp, Color = color, Prefix = char.Name, Type = "Player", Model = char }
                end
            end
        end
    end

    -- ZWIERZĘTA
    if SETTINGS.AnimalESP then
        local function scanAnimals(parent)
            for _, npc in pairs(parent:GetChildren()) do
                local char = npc:FindFirstChild("Character")
                if char then
                    local hrp = char:FindFirstChild("HumanoidRootPart")
                    if hrp then
                        local key = "ANIMAL_" .. npc:GetDebugId()
                        activeKeys[key] = true
                        local color = GetAnimalColor(char)
                        local colorName = GetColorName(color)
                        local prefix = string.format("%s - %s", npc.Name, colorName)
                        TrackedTargets[key] = { Part = hrp, Color = color, Prefix = prefix, Type = "Animal", Model = char }
                    end
                end
            end
        end
        local npcs = workspace:FindFirstChild("NPCs")
        if npcs then
            local animals = npcs:FindFirstChild("Animals")
            if animals then scanAnimals(animals) end
            local birds = npcs:FindFirstChild("Birds")
            if birds then scanAnimals(birds) end
        end
    end

    -- NPC BOUNTY
    if SETTINGS.NPCHumanESP then
        local npcs = workspace:FindFirstChild("NPCs")
        if npcs then
            local humans = npcs:FindFirstChild("Humans")
            if humans then
                local bounty = humans:FindFirstChild("BountyCombatNPCs")
                if bounty then
                    for _, npc in pairs(bounty:GetChildren()) do
                        local char = npc:FindFirstChild("Character")
                        if char then
                            local hrp = char:FindFirstChild("HumanoidRootPart")
                            if hrp then
                                local key = "NPCH_" .. npc:GetDebugId()
                                activeKeys[key] = true
                                TrackedTargets[key] = { Part = hrp, Color = Color3.fromRGB(255, 255, 0), Prefix = npc.Name, Type = "NPCHuman", Model = char }
                            end
                        end
                    end
                end
            end
        end
    end

    -- DOMY GRACZY
    if SETTINGS.PlayerHouseESP then
        local props = workspace:FindFirstChild("Props")
        if props then
            local houses = props:FindFirstChild("PlayerHouses")
            if houses then
                for _, house in pairs(houses:GetChildren()) do
                    local part = FindBestTargetPart(house)
                    if part then
                        local key = "HOUSE_" .. house:GetDebugId()
                        activeKeys[key] = true
                        TrackedTargets[key] = { Part = part, Color = Color3.fromRGB(0, 255, 255), Prefix = house.Name, Type = "PlayerHouse", Model = house }
                    end
                end
            end
        end
    end

    -- Funkcja skanująca Resources
    local function scanResources(parentFolder)
        local resources = parentFolder:FindFirstChild("Resources")
        if not resources then return end
        for _, res in pairs(resources:GetChildren()) do
            if not res:IsA("Model") then continue end
            local hasOres = res:FindFirstChild("Ores")
            if hasOres then
                if SETTINGS.OreESP then
                    local orePart
                    for _, child in pairs(hasOres:GetChildren()) do
                        if child:IsA("BasePart") and child.Name ~= "Ignore" then orePart = child; break end
                    end
                    if orePart then
                        local key = "ORE_" .. res:GetDebugId()
                        activeKeys[key] = true
                        local color = GetOreColor(hasOres)
                        TrackedTargets[key] = { Part = orePart, Color = color, Prefix = res.Name, Type = "Ore", Model = res }
                    end
                end
            elseif SETTINGS.TreeESP or SETTINGS.VegetationESP then
                local hasPlant = res:FindFirstChild("Plant")
                local hasFruits = res:FindFirstChild("Fruits")
                if hasPlant or hasFruits then
                    if SETTINGS.VegetationESP then
                        local vegPart
                        if hasPlant then vegPart = FindBestTargetPart(hasPlant)
                        elseif hasFruits then
                            for _, fruit in pairs(hasFruits:GetChildren()) do
                                if fruit:IsA("BasePart") then vegPart = fruit; break end
                            end
                        end
                        if vegPart then
                            local key = "VEG_" .. res:GetDebugId()
                            activeKeys[key] = true
                            local color = Color3.fromRGB(0, 255, 100)
                            TrackedTargets[key] = { Part = vegPart, Color = color, Prefix = res.Name, Type = "Vegetation", Model = res }
                        end
                    end
                else
                    if SETTINGS.TreeESP then
                        local part = FindBestTargetPart(res)
                        if part then
                            local key = "TREE_" .. res:GetDebugId()
                            activeKeys[key] = true
                            local color = GetTreeColor(res)
                            TrackedTargets[key] = { Part = part, Color = color, Prefix = res.Name, Type = "Tree", Model = res }
                        end
                    end
                end
            end
        end
    end

    local staticProps = workspace:FindFirstChild("StaticProps")
    if staticProps then scanResources(staticProps) end
    local targetFilter = workspace:FindFirstChild("TargetFilter")
    if targetFilter then scanResources(targetFilter) end

    -- SKRZYNIE
    if SETTINGS.ChestESP then
        local sp = workspace:FindFirstChild("StaticProps")
        if sp then
            local chests = sp:FindFirstChild("SmallChests")
            if chests then
                for _, chest in pairs(chests:GetChildren()) do
                    if chest:IsA("Model") then
                        local part = FindBestTargetPart(chest)
                        if part then
                            local key = "CHEST_" .. chest:GetDebugId()
                            activeKeys[key] = true
                            TrackedTargets[key] = { Part = part, Color = Color3.fromRGB(255, 215, 0), Prefix = chest.Name, Type = "Chest", Model = chest }
                        end
                    end
                end
            end
        end
    end

    -- PORZUCONE PRZEDMIOTY
    if SETTINGS.DroppedItemsESP then
        local carriables = workspace:FindFirstChild("Carriables")
        if carriables then
            for _, item in pairs(carriables:GetChildren()) do
                local part = FindBestTargetPart(item)
                if part then
                    local key = "DROPPED_" .. item:GetDebugId()
                    activeKeys[key] = true
                    TrackedTargets[key] = { Part = part, Color = Color3.fromRGB(255, 165, 0), Prefix = item.Name, Type = "DroppedItem", Model = item }
                end
            end
        end
    end

    -- TREASURE HUNT MARKERS
    if SETTINGS.TreasureMarkerESP then
        local function scanMarkers(parent)
            local markers = parent:FindFirstChild("TreasureHuntMarkers")
            if markers then
                for _, marker in pairs(markers:GetChildren()) do
                    local part = FindBestTargetPart(marker)
                    if part then
                        local key = "MARKER_" .. marker:GetDebugId()
                        activeKeys[key] = true
                        TrackedTargets[key] = { Part = part, Color = Color3.fromRGB(255, 105, 180), Prefix = marker.Name, Type = "TreasureMarker", Model = marker }
                    end
                end
            end
        end
        local props = workspace:FindFirstChild("Props")
        if props then scanMarkers(props) end
        local targetFilter = workspace:FindFirstChild("TargetFilter")
        if targetFilter then scanMarkers(targetFilter) end
    end

    -- Usuwanie starych wpisów
    for key, _ in pairs(TrackedTargets) do
        if not activeKeys[key] then
            if CACHE[key] then CACHE[key]:Destroy(); CACHE[key] = nil end
            if SELECTION_BOX_CACHE[key] then SELECTION_BOX_CACHE[key]:Destroy(); SELECTION_BOX_CACHE[key] = nil end
            TrackedTargets[key] = nil
        end
    end
end

local ScannerLoop = task.spawn(function()
    while task.wait(1.5) do
