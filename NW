local function SaveConfig()
    pcall(function()
        if writefile then
            makefolder("UniversalESP")
            local data = {}
            for k, v in pairs(SETTINGS) do
                if type(v) == "Color3" then data[k] = {v.R, v.G, v.B}
                else data[k] = v end
            end
            data.MenuKey = tostring(Window.ToggleKey)
            writefile("UniversalESP/ESPConfig.json", game:GetService("HttpService"):JSONEncode(data))
        end
    end)
end

local function LoadConfig()
    pcall(function()
        if readfile then
            local raw = readfile("UniversalESP/ESPConfig.json")
            local data = game:GetService("HttpService"):JSONDecode(raw)
            for k, v in pairs(data) do
                if k == "ESPColor" or k:find("Color") then
                    if type(v) == "table" and #v == 3 then SETTINGS[k] = Color3.new(v[1], v[2], v[3]) end
                elseif k == "MenuKey" then
                    local ok, key = pcall(function() return Enum.KeyCode[v] end)
                    if ok and key then Window:SetToggleKey(key) end
                elseif SETTINGS[k] ~= nil then SETTINGS[k] = v end
            end
        end
    end)
end

