local RenderLoop = RunService.RenderStepped:Connect(function()
    -- ESP
    if SETTINGS.Enabled then
        for key, target in pairs(TrackedTargets) do
            local typeEnabled = false
            local showName = false
            local drawSelectBox = false

            if target.Type == "Player" and SETTINGS.PlayerESP then
                typeEnabled = true; showName = SETTINGS.PlayerName; drawSelectBox = SETTINGS.PlayerSelectBox
            elseif target.Type == "Animal" and SETTINGS.AnimalESP then
                typeEnabled = true; showName = SETTINGS.AnimalName; drawSelectBox = SETTINGS.AnimalSelectBox
            elseif target.Type == "NPCHuman" and SETTINGS.NPCHumanESP then
                typeEnabled = true; showName = SETTINGS.NPCHumanName; drawSelectBox = SETTINGS.NPCHumanSelectBox
            elseif target.Type == "PlayerHouse" and SETTINGS.PlayerHouseESP then
                typeEnabled = true; showName = SETTINGS.PlayerHouseName; drawSelectBox = SETTINGS.PlayerHouseSelectBox
            elseif target.Type == "Tree" and SETTINGS.TreeESP then
                typeEnabled = true; showName = SETTINGS.TreeName; drawSelectBox = SETTINGS.TreeSelectBox
            elseif target.Type == "Ore" and SETTINGS.OreESP then
                typeEnabled = true; showName = SETTINGS.OreName; drawSelectBox = SETTINGS.OreSelectBox
            elseif target.Type == "Vegetation" and SETTINGS.VegetationESP then
                typeEnabled = true; showName = SETTINGS.VegetationName; drawSelectBox = SETTINGS.VegetationSelectBox
            elseif target.Type == "Chest" and SETTINGS.ChestESP then
                typeEnabled = true; showName = SETTINGS.ChestName; drawSelectBox = SETTINGS.ChestSelectBox
            elseif target.Type == "DroppedItem" and SETTINGS.DroppedItemsESP then
                typeEnabled = true; showName = SETTINGS.DroppedItemsName; drawSelectBox = SETTINGS.DroppedItemsSelectBox
            elseif target.Type == "TreasureMarker" and SETTINGS.TreasureMarkerESP then
                typeEnabled = true; showName = SETTINGS.TreasureMarkerName; drawSelectBox = SETTINGS.TreasureMarkerSelectBox
            end

            if not typeEnabled or not target.Part or not target.Part.Parent then
                if CACHE[key] then CACHE[key]:Destroy(); CACHE[key] = nil end
                if SELECTION_BOX_CACHE[key] then SELECTION_BOX_CACHE[key].Visible = false end
                continue
            end

            local dist = math.floor((Camera.CFrame.Position - target.Part.Position).Magnitude)
            local inRange = dist <= SETTINGS.MaxDistance

            if inRange and showName then
                local text = target.Prefix .. " [" .. dist .. "m]"
                if not CACHE[key] then
                    CACHE[key] = CreateESP(target.Part, text, target.Color)
                else
                    local lbl = CACHE[key]:FindFirstChildOfClass("TextLabel")
                    if lbl then lbl.Text = text; lbl.TextColor3 = target.Color end
                    CACHE[key].Enabled = true
                end
            else
                if CACHE[key] then CACHE[key].Enabled = false end
            end

            if inRange and drawSelectBox then
                local adornee = target.Model or target.Part
                if not SELECTION_BOX_CACHE[key] then
                    SELECTION_BOX_CACHE[key] = CreateSelectionBox(adornee, target.Color)
                else
                    UpdateSelectionBox(SELECTION_BOX_CACHE[key], target.Color)
                    SELECTION_BOX_CACHE[key].Adornee = adornee
                end
            else
                if SELECTION_BOX_CACHE[key] then SELECTION_BOX_CACHE[key].Visible = false end
            end
        end
    end

    -- AIMBOT
    if SETTINGS.AimbotEnabled then
        -- Rysowanie FOV
        if FOVCircle then
            FOVCircle.Radius = SETTINGS.AimbotFOV
            FOVCircle.Position = Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y / 2)
            FOVCircle.Visible = true
            if SETTINGS.AimbotMouseFOV then
                local mousePos = UserInputService:GetMouseLocation()
                FOVCircle.Position = Vector2.new(mousePos.X, mousePos.Y)
            end
            FOVCircle.Color = LockedTarget and Color3.fromRGB(255, 70, 70) or Color3.fromRGB(255, 255, 255)
        end

        if AimbotRunning then
            -- Logika wyboru celu
            if SETTINGS.AimbotStickyAim and LockedTarget then
                local char = LockedTarget.Character
                if char and char.Parent then
                    if CheckTeam(LockedTarget) or not CheckAlive(char) or CheckWall(char) then
                        CancelLock()
                    else
                        local aimPart = GetAimPart(char)
                        if aimPart then
                            local screenPos, onScreen = Camera:WorldToScreenPoint(aimPart.Position)
                            if not onScreen then
                                CancelLock()
                            else
                                local pos = Vector2.new(screenPos.X, screenPos.Y)
                                local screenCenter = SETTINGS.AimbotMouseFOV and Vector2.new(UserInputService:GetMouseLocation().X, UserInputService:GetMouseLocation().Y) or Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y / 2)
                                if (pos - screenCenter).Magnitude > SETTINGS.AimbotFOV then
                                    CancelLock()
                                else
                                    AimAt(aimPart)
                                end
                            end
                        else
                            CancelLock()
                        end
                    end
                else
                    CancelLock()
                end
            end

            if not SETTINGS.AimbotStickyAim or not LockedTarget then
                local targetPlayer, targetPart = GetClosestPlayer()
                if targetPlayer and targetPart then
                    LockedTarget = targetPlayer
                    AimAt(targetPart)
                else
                    CancelLock()
                end
            end
        else
            CancelLock()
            RestoreCamera()
        end
    else
        if FOVCircle then FOVCircle.Visible = false end
        CancelLock()
        RestoreCamera()
    end
end)

UserInputService.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton2 then
        if SETTINGS.AimbotEnabled then
            if SETTINGS.AimbotToggle then
                AimbotRunning = not AimbotRunning
                if not AimbotRunning then RestoreCamera() end
            else
                AimbotRunning = true
            end
        end
    end
end)

UserInputService.InputEnded:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton2 then
        if not SETTINGS.AimbotToggle then
            AimbotRunning = false
            CancelLock()
            RestoreCamera()
        end
    end
end)

