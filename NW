-- Funkcje pomocnicze aimbota
local function GetAimPart(char)
    if SETTINGS.AimbotTargetPart == "Head" then
        return char:FindFirstChild("Head")
    else
        return char:FindFirstChild("HumanoidRootPart")
    end
end

local function CheckTeam(player)
    if SETTINGS.AimbotTeamCheck and player and player.Team == LocalPlayer.Team then
        return true
    end
    return false
end

local function CheckAlive(character)
    if SETTINGS.AimbotAliveCheck then
        local humanoid = character:FindFirstChildOfClass("Humanoid")
        if humanoid and humanoid.Health <= 0 then
            return false
        end
    end
    return true
end

local function CheckWall(targetCharacter)
    if not SETTINGS.AimbotWallCheck then return false end
    local targetHead = targetCharacter:FindFirstChild("Head")
    if not targetHead then return true end
    local origin = Camera.CFrame.Position
    local direction = (targetHead.Position - origin).unit * (targetHead.Position - origin).magnitude
    local raycastParams = RaycastParams.new()
    raycastParams.FilterDescendantsInstances = {LocalPlayer.Character, targetCharacter}
    raycastParams.FilterType = Enum.RaycastFilterType.Blacklist
    local raycastResult = workspace:Raycast(origin, direction, raycastParams)
    return raycastResult ~= nil
end

local AimbotRunning = false
local LockedTarget = nil
local CurrentTween = nil

local function CancelLock()
    LockedTarget = nil
    if CurrentTween then
        CurrentTween:Cancel()
        CurrentTween = nil
    end
end

local function RestoreCamera()
    if Camera.CameraType == Enum.CameraType.Scriptable then
        Camera.CameraType = Enum.CameraType.Custom
        local character = LocalPlayer.Character
        if character then
            local humanoid = character:FindFirstChildOfClass("Humanoid")
            if humanoid then
                Camera.CameraSubject = humanoid
            end
        end
    end
end

local function GetClosestPlayer()
    local targetPlayer = nil
    local targetPart = nil
    local shortestDistance = SETTINGS.AimbotFOV

    local screenCenter = Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y / 2)

    for _, target in pairs(TrackedTargets) do
        if target.Type == "Player" then
            local char = target.Model
            if char and char.Parent then
                local player = Players:FindFirstChild(char.Name)
                if player and player ~= LocalPlayer then
                    if CheckTeam(player) then continue end
                    if not CheckAlive(char) then continue end
                    if CheckWall(char) then continue end

                    local aimPart = GetAimPart(char)
                    if aimPart then
                        local screenPos, onScreen = Camera:WorldToScreenPoint(aimPart.Position)
                        if onScreen then
                            local dist = (Vector2.new(screenPos.X, screenPos.Y) - screenCenter).Magnitude
                            if dist <= SETTINGS.AimbotFOV then
                                if dist < shortestDistance then
                                    shortestDistance = dist
                                    targetPlayer = player
                                    targetPart = aimPart
                                end
                            end
                        end
                    end
                end
            end
        end
    end

    return targetPlayer, targetPart
end

local function AimAt(targetPart)
    if not targetPart or not targetPart.Parent then
        CancelLock()
        return
    end

    local targetPos = targetPart.Position
    if SETTINGS.AimbotPrediction then
        local character = targetPart.Parent
        local hrp = character:FindFirstChild("HumanoidRootPart")
        if hrp then
            targetPos = targetPos + (hrp.Velocity * SETTINGS.AimbotPredictionStr)
        end
    end

    if SETTINGS.AimbotMethod == "Camera" then
        -- Metoda Camera: kamera pozostaje w obecnym miejscu, tylko obraca się w kierunku celu
        if SETTINGS.AimbotOverrideCamera then
            Camera.CameraType = Enum.CameraType.Scriptable
            Camera.CameraSubject = nil
        end
        local desiredCFrame = CFrame.new(Camera.CFrame.Position, targetPos)
        -- Płynny obrót (smoothing)
        Camera.CFrame = Camera.CFrame:Lerp(desiredCFrame, SETTINGS.AimbotSmoothing)
    else
        -- Metoda Mouse: przesuwa kursor dokładnie na pozycję celu na ekranie
        local screenPos = Camera:WorldToScreenPoint(targetPos)
        local mousePos = UserInputService:GetMouseLocation()
        local sens = math.clamp(SETTINGS.AimbotThirdPersonSens, 0.1, 10)
        local deltaX = (screenPos.X - mousePos.X) / sens
        local deltaY = (screenPos.Y - mousePos.Y) / sens
        mousemoverel(deltaX, deltaY)
    end
end

