local TEAM_COLORS = {
    ["Citizens"] = Color3.fromRGB(0, 255, 0),
    ["Lawmen"]   = Color3.fromRGB(0, 170, 255),
    ["Outlaws"]  = Color3.fromRGB(255, 0, 0),
}

local function GetPlayerColor(plr)
    if plr and plr.Team then
        return TEAM_COLORS[plr.Team.Name] or SETTINGS.ESPColor
    end
    return SETTINGS.ESPColor
end

local function GetAnimalColor(model)
    local body = model:FindFirstChild("Torso") or model:FindFirstChild("Body") or model:FindFirstChild("Head")
    if body and body:IsA("BasePart") then return body.Color end
    return Color3.fromRGB(255, 170, 0)
end

local function GetColorName(color)
    local r,g,b = math.floor(color.R*255), math.floor(color.G*255), math.floor(color.B*255)
    if r < 30 and g < 30 and b < 30 then return "Black"
    elseif r > 200 and g > 200 and b > 200 then return "White"
    elseif r > 200 and g < 50 and b < 50 then return "Red"
    elseif r < 50 and g > 150 and b < 50 then return "Green"
    elseif r < 50 and g < 50 and b > 150 then return "Blue"
    elseif r > 200 and g > 100 and b < 50 then return "Orange"
    elseif r > 200 and g > 200 and b < 50 then return "Yellow"
    elseif r > 100 and g > 50 and b < 50 then return "Brown"
    elseif r < 80 and g < 80 and b < 80 then return "Dark Gray"
    elseif r > 150 and g > 150 and b > 150 then return "Light Gray"
    elseif r > 180 and g < 100 and b > 180 then return "Purple"
    elseif r > 180 and g > 180 and b < 100 then return "Olive"
    elseif r < 100 and g > 180 and b > 180 then return "Cyan"
    else return "Unknown" end
end

local function GetTreeColor(model)
    local leaves = model:FindFirstChild("Leaves") or model:FindFirstChild("Leaf") or model:FindFirstChild("foliage")
    if leaves and leaves:IsA("BasePart") then return leaves.Color end
    return Color3.fromRGB(0, 200, 50)
end

local function GetOreColor(model)
    for _, child in pairs(model:GetChildren()) do
        if child:IsA("BasePart") and child.Name ~= "Ignore" then return child.Color end
    end
    return Color3.fromRGB(100, 200, 255)
end

local function FindBestTargetPart(model)
    if not model then return nil end
    if model:IsA("BasePart") then return model end
    if model:IsA("Model") then
        if model.PrimaryPart then return model.PrimaryPart end
        for _, part in pairs(model:GetChildren()) do if part:IsA("BasePart") then return part end end
        for _, part in pairs(model:GetDescendants()) do if part:IsA("BasePart") then return part end end
    end
    return nil
end

