local function AddCategory(category, prefix)
    local mainFlag = prefix .. "ESP"
    local nameFlag = prefix .. "Name"
    local selectFlag = prefix .. "SelectBox"

    local mainToggle = TypeSection:Toggle({
        Title = category,
        Value = SETTINGS[mainFlag],
        Callback = function(v)
            SETTINGS[mainFlag] = v
            SaveConfig()
            nameToggle:SetVisible(v)
            selectToggle:SetVisible(v)
        end
    })

    local nameToggle = TypeSection:Toggle({
        Title = "   Nazwa",
        Value = SETTINGS[nameFlag],
        Visible = SETTINGS[mainFlag],
        Callback = function(v)
            SETTINGS[nameFlag] = v
            SaveConfig()
        end
    })
    local selectToggle = TypeSection:Toggle({
        Title = "   Select Box (3D)",
        Value = SETTINGS[selectFlag],
        Visible = SETTINGS[mainFlag],
        Callback = function(v)
            SETTINGS[selectFlag] = v
            SaveConfig()
        end
    })
end

