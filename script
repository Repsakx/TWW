local function ClearESP()
    for _, v in pairs(CACHE) do
        if v and v.Parent then v:Destroy() end
    end
    table.clear(CACHE)
    for _, sb in pairs(SELECTION_BOX_CACHE) do
        if sb and sb.Parent then sb:Destroy() end
    end
    table.clear(SELECTION_BOX_CACHE)
    table.clear(TrackedTargets)

    local oldEsp = LocalPlayer.PlayerGui:FindFirstChild("ESPContainer")
    if oldEsp then oldEsp:Destroy() end
    local oldSelBox = workspace:FindFirstChild("SelectionBoxContainer")
    if oldSelBox then oldSelBox:Destroy() end

    ESPContainer = Instance.new("Folder")
    ESPContainer.Name = "ESPContainer"
    ESPContainer.Parent = LocalPlayer.PlayerGui
    SELECTION_BOX_CONTAINER = Instance.new("Folder")
    SELECTION_BOX_CONTAINER.Name = "SelectionBoxContainer"
    SELECTION_BOX_CONTAINER.Parent = workspace
end

-- Kolory drużyn
local TEAM_COLORS = {
    ["Citizens"] = Color3.fromRGB(0, 255, 0),
    ["Lawmen"]   = Color3.fromRGB(0, 170, 255),
    ["Outlaws"]  = Color3.fromRGB(255, 0, 0),
}

local function GetPlayerColor(plr)
    if plr and plr.Team then
        return TEAM_COLORS[plr.Team.Name] or SETTINGS.ESPColor
    end
    return SETTINGS.ESPColor
end

local function GetOreColor(model)
    local ore = model:FindFirstChild("RockOre", true)
    if ore and ore:IsA("BasePart") then return ore.Color end
    return Color3.fromRGB(100, 200, 255)
end

local function GetTreeColor(model)
    local leaves = model:FindFirstChild("Leaves", true) or model:FindFirstChild("JungleTree01_Leaves", true)
    if leaves and leaves:IsA("BasePart") then return leaves.Color end
    local trunk = model:FindFirstChild("Trunk", true)
    if trunk and trunk:IsA("BasePart") then return trunk.Color end
    return Color3.fromRGB(0, 200, 50)
end

local function GetAnimalColor(model)
    local body = model:FindFirstChild("Body", true)
    if body and body:IsA("BasePart") then return body.Color end
    return Color3.fromRGB(255, 170, 0)
end

local function GetDroppedItemColor(item)
    -- dla uproszczenia biały, można dostosować
    return Color3.fromRGB(255, 255, 0)
end

local function FindBestTargetPart(model)
    if not model then return nil end
    if model:IsA("BasePart") then return model end
    if model:IsA("Model") and model.PrimaryPart then return model.PrimaryPart end
    local hrp = model:FindFirstChild("HumanoidRootPart") or model:FindFirstChild("HumanoidRootPart", true)
    if hrp and hrp:IsA("BasePart") then return hrp end
    local body = model:FindFirstChild("Body") or model:FindFirstChild("Body", true)
    if body and body:IsA("BasePart") then return body end
    for _, part in pairs(model:GetDescendants()) do
        if part:IsA("BasePart") then return part end
    end
    return nil
end

local function CreateESP(part, text, color)
    local bb = Instance.new("BillboardGui")
    bb.AlwaysOnTop = true
    bb.Size = UDim2.new(0, 200, 0, 30)
    bb.StudsOffset = Vector3.new(0, 2.5, 0)
    bb.Adornee = part
    bb.Parent = ESPContainer

    local lbl = Instance.new("TextLabel")
    lbl.BackgroundTransparency = 1
    lbl.Size = UDim2.new(1, 0, 1, 0)
    lbl.Font = Enum.Font.GothamBold
    lbl.TextScaled = false
    lbl.TextSize = 11
    lbl.TextStrokeTransparency = 0.25
    lbl.TextStrokeColor3 = Color3.new(0, 0, 0)
    lbl.TextColor3 = color
    lbl.Text = text
    lbl.Parent = bb

    return bb, lbl
end

-- Select Box (3D)
local function CreateSelectionBox(adornee, color)
    if not adornee then return nil end
    local sb = Instance.new("SelectionBox")
    sb.Name = "ESP_SelectBox"
    sb.Adornee = adornee
    sb.Color3 = color
    sb.LineThickness = SETTINGS.SelectBoxLineThickness
    sb.SurfaceColor3 = color
    sb.SurfaceTransparency = SETTINGS.SelectBoxSurfaceTransparency
    sb.Visible = true
    sb.Parent = SELECTION_BOX_CONTAINER
    return sb
end

local function UpdateSelectionBox(sb, color)
    if not sb then return end
    sb.Color3 = color
    sb.SurfaceColor3 = color
    sb.LineThickness = SETTINGS.SelectBoxLineThickness
    sb.SurfaceTransparency = SETTINGS.SelectBoxSurfaceTransparency
    sb.Visible = true
end

