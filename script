local TrackedTargets = {}

local function ScanEntities()
    local activeKeys = {}

    -- Gracze
    if SETTINGS.PlayerESP then
        local pf = workspace:FindFirstChild("WORKSPACE_Entities") and workspace.WORKSPACE_Entities:FindFirstChild("Players")
        if pf then
            for _, char in pairs(pf:GetChildren()) do
                local hrp = char:FindFirstChild("HumanoidRootPart")
                if hrp then
                    local key = "PLAYER_" .. char.Name
                    activeKeys[key] = true
                    local plr = Players:FindFirstChild(char.Name)
                    TrackedTargets[key] = { Part = hrp, Color = GetPlayerColor(plr), Prefix = char.Name, Type = "Player", Model = char }
                end
            end
        end
    end

    -- NPC
    if SETTINGS.NPCESP then
        local nf = workspace:FindFirstChild("WORKSPACE_Entities") and workspace.WORKSPACE_Entities:FindFirstChild("NPCs")
        if nf then
            for _, npc in pairs(nf:GetChildren()) do
                local model = npc:FindFirstChild("Model")
                local hrp = model and model:FindFirstChild("HumanoidRootPart", true)
                if hrp then
                    local key = "NPC_" .. npc.Name
                    activeKeys[key] = true
                    TrackedTargets[key] = { Part = hrp, Color = Color3.fromRGB(255, 255, 0), Prefix = npc.Name, Type = "NPC", Model = model or npc }
                end
            end
        end
    end

    -- Zwierzęta
    if SETTINGS.AnimalESP then
        local af = workspace:FindFirstChild("WORKSPACE_Entities") and workspace.WORKSPACE_Entities:FindFirstChild("Animals")
        if af then
            for _, animal in pairs(af:GetChildren()) do
                local bestPart = FindBestTargetPart(animal)
                if bestPart then
                    local key = "ANIMAL_" .. animal:GetDebugId()
                    activeKeys[key] = true
                    local health = animal:FindFirstChild("Health") and animal.Health.Value or "?"
                    local anger = animal:FindFirstChild("Anger") and animal.Anger.Value or "?"
                    local prefix = string.format("%s [HP:%s] [Anger:%s]", animal.Name, tostring(health), tostring(anger))
                    TrackedTargets[key] = { Part = bestPart, Color = GetAnimalColor(animal), Prefix = prefix, Type = "Animal", Model = animal }
                end
            end
        end
    end

    -- Rudy
    if SETTINGS.OreESP then
        local mining = workspace:FindFirstChild("WORKSPACE_Interactables") and workspace.WORKSPACE_Interactables:FindFirstChild("Mining")
        local of = mining and mining:FindFirstChild("OreDeposits")
        if of then
            for _, oreType in pairs(of:GetChildren()) do
                for _, deposit in pairs(oreType:GetChildren()) do
                    local rock = deposit:FindFirstChild("RockOre", true)
                    if rock and rock:IsA("BasePart") then
                        local info = deposit:FindFirstChild("DepositInfo")
                        local progress = info and info:FindFirstChild("Progress") and info.Progress.Value or "?"
                        local maxHealth = info and info:FindFirstChild("MaxHealth") and info.MaxHealth.Value or "?"
                        local remaining = tostring(progress) .. "/" .. tostring(maxHealth)
                        local key = "ORE_" .. deposit:GetDebugId()
                        activeKeys[key] = true
                        TrackedTargets[key] = { Part = rock, Color = GetOreColor(deposit), Prefix = oreType.Name .. " (" .. remaining .. ")", Type = "Ore", Model = deposit }
                    end
                end
            end
        end
    end

    -- Drzewa
    if SETTINGS.TreeESP then
        local geo = workspace:FindFirstChild("WORKSPACE_Geometry")
        if geo then
            for _, region in pairs(geo:GetChildren()) do
                local trees = region:FindFirstChild("Trees")
                if trees then
                    for _, tree in pairs(trees:GetChildren()) do
                        local treeInfo = tree:FindFirstChild("TreeInfo")
                        if treeInfo and treeInfo:FindFirstChild("Alive") and treeInfo.Alive.Value == true then
                            local part = tree:FindFirstChild("Leaves", true) or tree:FindFirstChild("JungleTree01_Leaves", true) or tree:FindFirstChild("Trunk", true)
                            if part and part:IsA("BasePart") then
                                local hp = treeInfo:FindFirstChild("Health")
                                local health = hp and tostring(hp.Value) or "?"
                                local key = "TREE_" .. tree:GetDebugId()
                                activeKeys[key] = true
                                TrackedTargets[key] = { Part = part, Color = GetTreeColor(tree), Prefix = tree.Name .. " (HP: " .. health .. ")", Type = "Tree", Model = tree }
                            end
                        end
                    end
                end
            end
        end
    end

    -- Porzucone przedmioty
    if SETTINGS.DroppedItemsESP then
        local di = workspace:FindFirstChild("WORKSPACE_Interactables") and workspace.WORKSPACE_Interactables:FindFirstChild("DroppedItems")
        if di then
            for _, item in pairs(di:GetChildren()) do
                local bestPart = FindBestTargetPart(item)
                if bestPart then
                    local key = "ITEM_" .. item:GetDebugId()
                    activeKeys[key] = true
                    TrackedTargets[key] = { Part = bestPart, Color = GetDroppedItemColor(item), Prefix = item.Name, Type = "DroppedItem", Model = item }
                end
            end
        end
    end

    -- Usuwanie starych wpisów
    for key, _ in pairs(TrackedTargets) do
        if not activeKeys[key] then
            if CACHE[key] then CACHE[key]:Destroy(); CACHE[key] = nil end
            if SELECTION_BOX_CACHE[key] then SELECTION_BOX_CACHE[key]:Destroy(); SELECTION_BOX_CACHE[key] = nil end
            TrackedTargets[key] = nil
        end
    end
end

local ScannerLoop = task.spawn(function()
    while task.wait(1.5) do
        if SETTINGS.Enabled then pcall(ScanEntities) end
    end
end)

local RenderLoop = RunService.RenderStepped:Connect(function()
    if not SETTINGS.Enabled then return end

    for key, target in pairs(TrackedTargets) do
        local typeEnabled = false
        local showName = false
        local drawSelectBox = false

        if target.Type == "Player" and SETTINGS.PlayerESP then
            typeEnabled = true
            showName = SETTINGS.PlayerName
            drawSelectBox = SETTINGS.PlayerSelectBox
        elseif target.Type == "NPC" and SETTINGS.NPCESP then
            typeEnabled = true
            showName = SETTINGS.NPCName
            drawSelectBox = SETTINGS.NPCSelectBox
        elseif target.Type == "Animal" and SETTINGS.AnimalESP then
            typeEnabled = true
            showName = SETTINGS.AnimalName
            drawSelectBox = SETTINGS.AnimalSelectBox
        elseif target.Type == "Ore" and SETTINGS.OreESP then
            typeEnabled = true
            showName = SETTINGS.OreName
            drawSelectBox = SETTINGS.OreSelectBox
        elseif target.Type == "Tree" and SETTINGS.TreeESP then
            typeEnabled = true
            showName = SETTINGS.TreeName
            drawSelectBox = SETTINGS.TreeSelectBox
        elseif target.Type == "DroppedItem" and SETTINGS.DroppedItemsESP then
            typeEnabled = true
            showName = SETTINGS.DroppedItemsName
            drawSelectBox = SETTINGS.DroppedItemsSelectBox
        end

        if not typeEnabled or not target.Part or not target.Part.Parent then
            if CACHE[key] then CACHE[key]:Destroy(); CACHE[key] = nil end
            if SELECTION_BOX_CACHE[key] then SELECTION_BOX_CACHE[key].Visible = false end
            continue
        end

        local dist = math.floor((Camera.CFrame.Position - target.Part.Position).Magnitude)
        local inRange = dist <= SETTINGS.MaxDistance

        -- Nazwa
        if inRange and showName then
            local text = target.Prefix .. " [" .. dist .. "m]"
            if not CACHE[key] then
                CACHE[key] = CreateESP(target.Part, text, target.Color)
            else
                local lbl = CACHE[key]:FindFirstChildOfClass("TextLabel")
                if lbl then lbl.Text = text; lbl.TextColor3 = target.Color end
                CACHE[key].Enabled = true
            end
        else
            if CACHE[key] then CACHE[key].Enabled = false end
        end

        -- Select Box (3D)
        if inRange and drawSelectBox then
            local adornee = target.Model or target.Part
            if not SELECTION_BOX_CACHE[key] then
                SELECTION_BOX_CACHE[key] = CreateSelectionBox(adornee, target.Color)
            else
                UpdateSelectionBox(SELECTION_BOX_CACHE[key], target.Color)
                SELECTION_BOX_CACHE[key].Adornee = adornee
            end
        else
            if SELECTION_BOX_CACHE[key] then
                SELECTION_BOX_CACHE[key].Visible = false
            end
        end
    end
end)

